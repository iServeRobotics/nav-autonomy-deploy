# Hardware Configuration Environment Variables
# Copy this file to .env and customize for your hardware setup

# ============================================
# NVIDIA GPU Support
# ============================================
# Set the Docker runtime to nvidia for GPU support (it's runc by default)
#DOCKER_RUNTIME=nvidia

# ============================================
# ROS Configuration
# ============================================
# ROS domain ID for multi-robot setups
ROS_DOMAIN_ID=42

# Robot configuration ('mechanum_drive', 'unitree/unitree_g1', 'unitree/unitree_g1', etc)
ROBOT_CONFIG_PATH=unitree/unitree_go2

# Robot IP address on local network for connection over WebRTC
# For Unitree Go2, Unitree G1, if using WebRTCConnection
# This can be found in the unitree app under Device settings or via network scan
ROBOT_IP=192.168.12.1

# Unitree robot specific settings
USE_UNITREE=true                                                                                                                      
UNITREE_IP=192.168.12.1                                                                                                               
UNITREE_CONN=LocalAP    
# ============================================
# Mid-360 Lidar Configuration
# ============================================
# Network interface connected to the lidar (e.g., eth0, enp0s3)
# Find with: ip addr show
LIDAR_INTERFACE=enP8p1s0

# Processing computer IP address on the lidar subnet
# Must be on the same subnet as the lidar (e.g., 192.168.1.5)
# LIDAR_COMPUTER_IP=192.168.123.5 # FOR UNITREE G1 EDU
LIDAR_COMPUTER_IP=192.168.1.5

# Gateway IP address for the lidar subnet
# LIDAR_GATEWAY=192.168.123.1 # FOR UNITREE G1 EDU
LIDAR_GATEWAY=192.168.1.1

# Full IP address of your Mid-360 lidar
# This should match the IP configured on your lidar device
# Common patterns: 192.168.1.1XX or 192.168.123.1XX
# LIDAR_IP=192.168.123.120 # FOR UNITREE G1 EDU
LIDAR_IP=192.168.1.131

# ============================================
# Motor Controller Configuration
# ============================================
# Serial device for motor controller
# Check with: ls /dev/ttyACM* or ls /dev/ttyUSB*
MOTOR_SERIAL_DEVICE=/dev/ttyACM0

# ============================================
# Network Communication (for base station)
# ============================================
# Enable WiFi buffer optimization for data transmission
# Set to true if using wireless base station
ENABLE_WIFI_BUFFER=false

# ============================================
# Display Configuration
# ============================================
# X11 display (usually auto-detected)
# DISPLAY=:0

USE_REALSENSE=false

# Localization/SLAM Method Selection
#LOCALIZATION_METHOD=arise_slam

# SLAM Voxel Resolution Configuration                                                                                                       
AUTO_VOXEL_SIZE=false                                                                                                                       
MAPPING_LINE_RESOLUTION=0.02                                                                                                                 
MAPPING_PLANE_RESOLUTION=0.02

# Use IMU gravity for roll/pitch correction in arise_slam (default: true)
# Recommended for tilted lidar mounts (e.g., Go2 at ~28 deg)
# Set to false to disable for flat mounts
#USE_IMU_ROLL_PITCH=false

# For FASTLIO2 localization with saved map (leave empty for mapping mode)
#MAP_PATH=~/Downloads/maps/current_map/map_pcl.pcd
VOXEL_RESOLUTION=0.05

# ============================================
# Goal Tolerance Configuration
# ============================================
# Distance threshold to consider goal reached (meters)
GOAL_REACHED_THRESHOLD=0.2
# Yaw threshold to consider goal reached (radians, 0.15 ≈ 8.6°)
GOAL_YAW_THRESHOLD=0.1
# Path follower stop distance (meters)
STOP_DIS_THRESHOLD=0.2

# ============================================
# Monitoring Configuration
# ============================================
# Target container for CPU/memory monitoring and log analysis
TARGET_CONTAINER=nav_autonomy
# Sampling interval for CPU/memory monitor (seconds)
MONITOR_INTERVAL=1.0

# ============================================
# Log Analyzer Configuration
# ============================================
# How often to write summary JSON (seconds)
SUMMARY_INTERVAL=60

# ============================================
# Cloud Sender Configuration (Omakase)
# ============================================
# ============================================
# Navigation Speed
# ============================================
# Autonomy speed for waypoint/goal navigation (0.0 to 2.0, default 1.0)
AUTONOMY_SPEED=0.5

CLOUD_API_URL=https://omakase-robotics.com
CLOUD_ROBOT_NAME=robot
CLOUD_VENDOR=iserve
CLOUD_ZONE=default
